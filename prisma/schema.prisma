generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  engineType      = "library"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id              String         @id @default(cuid())
  name            String
  slug            String         @unique
  description     String
  price           Float
  category        String
  images          ProductImage[]
  metaTitle       String?
  metaDescription String?
  keywords        String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Admin {
  id       String @id @default(cuid())
  password String
}
